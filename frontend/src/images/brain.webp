body {
  margin: 0;
  padding: 0;

  background-image: url('./images/brain.jpg');

  background-size: cover;

  background-position: center;

  background-repeat: no-repeat;

  height: 100vh;

  font-family: Arial;
}

.App {
  text-align: center;
  padding-top: 50px;
}

h1 {
  color: white;
}

form {
  background: rgba(255, 255, 255, 0.9);

  width: 300px;

  margin: auto;

  padding: 20px;

  border-radius: 10px;
}

input {
  width: 90%;

  padding: 10px;

  margin: 10px;
}

button {
  width: 100%;

  padding: 10px;

  background-color: blue;

  color: white;

  border: none;

  cursor: pointer;
}